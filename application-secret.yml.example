# 이 파일을 application-secret.yml 로 복사하고 실제 키를 채우세요 (application-secret.yml 은 gitignore됨).
# 프로젝트 루트에 두면 application.yml 의 spring.config.import 로 자동 로드됩니다.
# (또는 KMA_AUTH_KEY / DATA_GO_KR_SERVICE_KEY 환경변수로 주입해도 동작)
haeyaji:
  weather:
    kma:
      # apihub.kma.go.kr 인증키 (동네예보·중기예보)
      auth-key: YOUR_APIHUB_AUTHKEY
    datakr:
      # data.go.kr 서비스키 (생활기상지수 UV + 에어코리아 미세먼지, 계정당 1키)
      service-key: YOUR_DATA_GO_KR_SERVICEKEY
